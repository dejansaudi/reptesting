// Validately.io — Prisma Schema
// PostgreSQL with JSONB for 101-field project data

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────

enum Plan {
  FREE
  PRO
  TEAM
}

enum TeamRole {
  OWNER
  EDITOR
  VIEWER
}

enum ExportStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

// ─── User ────────────────────────────────────────────────

model User {
  id                 String   @id @default(cuid())
  email              String   @unique
  name               String?
  avatar             String?
  plan               Plan     @default(FREE)
  stripeCustomerId   String?  @unique
  encryptedApiKey    String? // AES-256-GCM encrypted BYOK Anthropic key
  onboardingComplete Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  projects    Project[]
  teamMembers TeamMember[]

  // NextAuth.js adapter fields
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions      Session[]

  @@map("users")
}

// ─── Project ─────────────────────────────────────────────

model Project {
  id         String   @id @default(cuid())
  name       String   @default("Untitled Startup")
  data       Json     @default("{}") // All 101 stage fields stored as JSONB
  version    Int      @default(1) // Optimistic locking — increment on every write
  irsScore   Int      @default(0) // Cached Investor Readiness Score for fast queries
  stageIdx   Int      @default(0) // Current stage index
  isPublic   Boolean  @default(false)
  publicSlug String?  @unique
  userId     String
  teamId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  team      Team?      @relation(fields: [teamId], references: [id], onDelete: SetNull)
  snapshots Snapshot[]

  @@index([userId])
  @@index([teamId])
  @@map("projects")
}

// ─── Snapshot ────────────────────────────────────────────

model Snapshot {
  id        String   @id @default(cuid())
  name      String
  data      Json // Full copy of project data at point-in-time
  stageIdx  Int      @default(0) // Stage index at time of snapshot
  branch    String? // Branch name this snapshot was taken from
  projectId String
  createdAt DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("snapshots")
}

// ─── Team ────────────────────────────────────────────────

model Team {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members  TeamMember[]
  projects Project[]

  @@map("teams")
}

// ─── TeamMember (join table: User <-> Team) ──────────────

model TeamMember {
  id        String   @id @default(cuid())
  role      TeamRole @default(VIEWER)
  userId    String
  teamId    String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([userId, teamId])
  @@index([userId])
  @@index([teamId])
  @@map("team_members")
}

// ─── ExportJob ────────────────────────────────────────────

model ExportJob {
  id          String       @id @default(cuid())
  type        String // 'pdf' | 'pitch-deck'
  status      ExportStatus @default(QUEUED)
  downloadUrl String? // Signed URL to R2/S3 once complete
  error       String?
  projectId   String
  userId      String
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  @@index([userId])
  @@index([projectId])
  @@map("export_jobs")
}

// ─── ScoreSnapshot (IRS history tracking) ────────────────

model ScoreSnapshot {
  id        String   @id @default(cuid())
  score     Int // IRS score at this point
  band      String // Band label (Pre-Seed, MVP, Seed, etc.)
  stageIdx  Int // Current stage at time of snapshot
  stages    Json // Per-stage breakdown { stage, passed, total, pct, weighted }
  projectId String
  createdAt DateTime @default(now())

  @@index([projectId])
  @@index([projectId, createdAt])
  @@map("score_snapshots")
}

// ─── NextAuth.js Adapter Models ──────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}
