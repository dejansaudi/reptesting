# ─── Database (required) ───
DATABASE_URL="postgresql://user:password@localhost:5432/validately?schema=public"

# ─── Auth (required) ───
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""           # openssl rand -base64 32
JWT_SECRET=""                # openssl rand -base64 48

# ─── Google OAuth (optional) ───
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ─── Encryption (optional - falls back to JWT_SECRET) ───
ENCRYPTION_SECRET=""         # openssl rand -base64 32

# ─── AI (optional - enables AI features) ───
ANTHROPIC_API_KEY=""

# ─── Stripe (optional - enables billing) ───
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRO_PRICE_ID=""
STRIPE_TEAM_PRICE_ID=""

# ─── Redis (optional - enables rate limiting & job queues) ───
REDIS_URL="redis://localhost:6379"

# ─── Email (optional - enables magic link & team invites) ───
RESEND_API_KEY=""

# ─── Storage (optional - enables cloud export storage) ───
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME="validately-exports"

# ─── API ───
NEXT_PUBLIC_API_URL="http://localhost:4000"

# ─── Observability (optional) ───
SENTRY_DSN=""
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
